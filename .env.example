# Copy to .env and fill in

# Researcher identity, sent on every active request as an attribution header.
# Required by most bug bounty programs so blue teams can whitelist your traffic.
RESEARCHER_NAME=cipherdecrypter
RESEARCHER_CONTACT=security-research@example.com

# Global requests-per-second cap applied by every phase that makes HTTP requests.
GLOBAL_RATE_LIMIT=5

# Where scan workspaces (raw tool output) are written.
WORKSPACE_DIR=./workspaces

# SQLite by default. Swap for postgresql+asyncpg://user:pass@host/db to scale up.
DATABASE_URL=sqlite+aiosqlite:///./bugbounty.db

# Optional: token for github-subdomains style GitHub code search during passive recon.
GITHUB_TOKEN=

# Optional: outbound webhook for "new finding" alerts (Slack/Discord/generic).
ALERT_WEBHOOK_URL=

# Enables the continuous monitoring scheduler on API startup.
ENABLE_SCHEDULER=true

# Safety switch. When true, active phases (nuclei, ffuf, cors probing, fuzzing)
# refuse to run against any target that isn't matched by the program's scope_regex.
# Leave this true unless you really know what you're doing.
ENFORCE_SCOPE=true
