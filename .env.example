# Copy to .env and fill in. Every value below has a safe default if you
# leave it blank — the platform runs with zero API keys, just with less
# passive-recon coverage per source.

# ---- Identity ----
# Sent on every active request as an attribution header. Most programs want
# an identifiable header on automated traffic so their blue team can tell
# it's you and not an actual attacker.
RESEARCHER_NAME=your_handle
RESEARCHER_CONTACT=you@example.com

# ---- Rate limiting / storage ----
GLOBAL_RATE_LIMIT=5
WORKSPACE_DIR=./workspaces
# SQLite by default. Swap for postgresql+asyncpg://user:pass@host/db to scale up.
DATABASE_URL=sqlite+aiosqlite:///./bugbounty.db

# ---- Passive OSINT source API keys (all optional) ----
# Each source is skipped (logged, not fatal) if its key is blank.
GITHUB_TOKEN=                 # github-subdomains: code search for leaked subdomains
SHODAN_API_KEY=               # Shodan host/subdomain search (InternetDB enrichment needs NO key — always on)
CENSYS_API_ID=                # Censys Search v2
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=       # historical DNS + subdomain enumeration
VIRUSTOTAL_API_KEY=           # passive DNS + subdomain enumeration
URLSCAN_API_KEY=              # urlscan.io search (works unauthenticated too, key raises quota)
CHAOS_API_KEY=                # ProjectDiscovery Chaos curated bug-bounty dataset
BINARYEDGE_API_KEY=           # BinaryEdge passive DNS/subdomains
LEAKIX_API_KEY=                # LeakIX exposed-service search

# ---- Alerting ----
# Optional global fallback outbound webhook (Slack/Discord-compatible) for
# "new finding" alerts. Per-program webhooks (set in the dashboard) take
# priority over this. Must be a public https/http URL — localhost/private
# IPs are rejected (SSRF guard).
ALERT_WEBHOOK_URL=

ENABLE_SCHEDULER=true

# Safety switch. When true, every active phase (nuclei, ffuf, CORS probing,
# takeover checks, fuzzing) refuses to touch any target that isn't matched
# by the program's scope_regex. Leave this true unless you really know what
# you're doing.
ENFORCE_SCOPE=true

# ---- Access control ----
# If set, both the dashboard (session-cookie login) and the JSON API
# (X-API-Key header) require this value. STRONGLY recommended the moment
# this app is reachable from anything other than 127.0.0.1 — an
# unauthenticated instance lets anyone who can reach it trigger scans
# against targets of THEIR choosing, from YOUR IP.
APP_PASSWORD=
# Signs dashboard session cookies. Leave blank and one is auto-generated and
# persisted to .session_secret on first run — only set this explicitly if
# you're running multiple instances that need to share sessions.
SESSION_SECRET=

# Point this at a real SecLists checkout for serious ffuf/x8 wordlist
# coverage; falls back to the small built-in lists in app/wordlists/ if this
# path doesn't exist.
SECLISTS_DIR=/usr/share/wordlists/seclists
